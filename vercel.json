{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/openai", "destination": "/api/openai" },
    { "source": "/api/gemini", "destination": "/api/gemini" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
